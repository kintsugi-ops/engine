{
  "name": "kintsugi-ops",
  "version": "0.1.0",
  "description": "Self-healing engine that automatically analyzes errors and creates fix PRs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kintsugi": "dist/cli/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.44.0",
    "@octokit/rest": "^22.0.1",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "openai": "^6.27.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "self-healing",
    "ai",
    "devops",
    "github-actions",
    "sentry"
  ],
  "license": "MIT",
  "overrides": {
    "glob": "^13.0.6"
  }
}